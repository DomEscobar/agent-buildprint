{
  "name": "agent-buildprint",
  "version": "0.0.5",
  "type": "module",
  "bin": {
    "agb": "./bin/agb.js"
  },
  "scripts": {
    "check:spine": "node scripts/check-buildprint-spine.mjs",
    "check:publication": "node scripts/check-publication.mjs",
    "check:mapper-output": "node scripts/check-mapper-selected-output.mjs buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-good/selected-buildprint buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-framework-good/selected-buildprint buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-integration-good/selected-buildprint buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-automation-good/selected-buildprint buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-data-pipeline-good/selected-buildprint buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-infrastructure-good/selected-buildprint buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-mixed-good/selected-buildprint",
    "check": "node -e \"const fs=require('fs'); fs.rmSync('/tmp/agb-check-smoke',{recursive:true,force:true}); fs.mkdirSync('/tmp/agb-check-smoke/code',{recursive:true}); const lines=['purpose: test','runtime:','  forbidden_dependencies:','    - forbidden-runtime','state:','  required_fields:','    - done','nodes:','  act:','    input:','      reads:','        - messages','    output:','      writes:','        - done','    side_effects: []','edges:','- from: start','to: act','- from: act','to: end','acceptance_criteria:','  - passes check']; fs.writeFileSync('/tmp/agb-check-smoke/blueprint.yaml', lines.join('\\n')+'\\n'); fs.writeFileSync('/tmp/agb-check-smoke/code/index.js','export const ok = true;\\n')\" && node ./bin/agb.js check /tmp/agb-check-smoke --code /tmp/agb-check-smoke/code",
    "test": "npm run check:spine && npm run check:publication && npm run check:mapper-output && npm run check:mapper-published && npm run check:mapper-output:negative && npm run check:mapper-replay:negative && npm run eval:mapper-golden && npm run eval:mapper-replay:dry-run && npm run check && npm run check:agb-start && node -e \"require('fs').rmSync('/tmp/agb-start-smoke',{recursive:true,force:true})\" && node ./bin/agb.js start https://agent-buildprint.com/buildprints/ai-influencer-os/package.json /tmp/agb-start-smoke && node -e \"const fs=require('fs'); for (const f of ['/tmp/agb-start-smoke/.buildprint/snapshots/BUILDPRINT.md','/tmp/agb-start-smoke/.buildprint/snapshots/plans/04-wavespeed-image.md']) { if (!fs.existsSync(f) || fs.statSync(f).size === 0) throw new Error('missing '+f) }\"",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "check:mapper-output:negative": "node scripts/check-mapper-negative-fixtures.mjs",
    "check:mapper-replay:negative": "node scripts/check-mapper-replay-negative-fixtures.mjs",
    "eval:mapper-golden": "node scripts/eval-mapper-golden.mjs",
    "eval:mapper-fast": "npm run check:mapper-output && npm run check:mapper-output:negative && npm run check:mapper-replay:negative && npm run eval:mapper-golden && npm run eval:ai-micro-replay:dry-run && npm run eval:ai-ui-micro-replay:dry-run",
    "audit:mapper-published": "node scripts/audit-mapper-published-packets.mjs",
    "check:mapper-published": "node scripts/audit-mapper-published-packets.mjs --strict",
    "eval:mapper-replay": "node scripts/eval-mapper-replay.mjs",
    "eval:mapper-replay:dry-run": "node scripts/eval-mapper-replay.mjs --dry-run",
    "eval:agent-smoke": "npm run eval:ai-micro-replay",
    "eval:agent-small": "npm run eval:ai-ui-micro-replay",
    "eval:agent-local-rag": "npm run eval:local-rag-phase1",
    "eval:ai-micro-replay": "node scripts/eval-mapper-replay.mjs --packet buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-ai-micro/selected-buildprint --timeout-ms 300000 --allow-timeout-after-pass --report quality/ai-micro-replay-report.json --transcript quality/ai-micro-replay-transcript.txt --archive quality/ai-micro-replay-workspace",
    "eval:ai-micro-replay:dry-run": "node scripts/eval-mapper-replay.mjs --packet buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-ai-micro/selected-buildprint --timeout-ms 300000 --dry-run",
    "eval:ai-ui-micro-replay": "node scripts/eval-mapper-replay.mjs --packet buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-ai-ui-micro/selected-buildprint --require-interactive-ui --timeout-ms 300000 --allow-timeout-after-pass --report quality/ai-ui-micro-replay-report.json --transcript quality/ai-ui-micro-replay-transcript.txt --archive quality/ai-ui-micro-replay-workspace",
    "eval:ai-ui-micro-replay:dry-run": "node scripts/eval-mapper-replay.mjs --packet buildprints/buildprint-mapper-os/evals/selected-output-fixtures/executable-packet-ai-ui-micro/selected-buildprint --require-interactive-ui --timeout-ms 300000 --dry-run",
    "eval:local-rag-phase1": "node scripts/eval-mapper-replay.mjs --packet buildprints/local-rag-chat-workbench --phase 01-provider-chat-runtime --require-interactive-ui --timeout-ms 480000 --allow-timeout-after-pass --report quality/local-rag-phase1-replay-report.json --transcript quality/local-rag-phase1-replay-transcript.txt --archive quality/local-rag-phase1-replay-workspace",
    "eval:local-rag-phase1:strict-ui": "node scripts/eval-mapper-replay.mjs --packet buildprints/local-rag-chat-workbench --phase 01-provider-chat-runtime --require-ui-proof --timeout-ms 480000 --allow-timeout-after-pass --report quality/local-rag-phase1-strict-ui-report.json --transcript quality/local-rag-phase1-strict-ui-transcript.txt --archive quality/local-rag-phase1-strict-ui-workspace",
    "eval:local-rag-phase2": "node scripts/eval-mapper-replay.mjs --packet buildprints/local-rag-chat-workbench --phase 02-document-rag-indexing --require-interactive-ui --timeout-ms 600000 --allow-timeout-after-pass --report quality/local-rag-phase2-replay-report.json --transcript quality/local-rag-phase2-replay-transcript.txt --archive quality/local-rag-phase2-replay-workspace",
    "eval:local-rag-replay": "node scripts/eval-mapper-replay.mjs --packet buildprints/local-rag-chat-workbench --timeout-ms 600000 --report quality/local-rag-replay-report.json --transcript quality/local-rag-replay-transcript.txt --archive quality/local-rag-replay-workspace",
    "eval:local-rag-replay:dry-run": "node scripts/eval-mapper-replay.mjs --packet buildprints/local-rag-chat-workbench --timeout-ms 600000 --dry-run",
    "eval:swarm-phase2": "node scripts/eval-mapper-replay.mjs --packet buildprints/ai-swarm-simulator --phase 02-graph-memory-build --require-interactive-ui --timeout-ms 900000 --report quality/swarm-phase2-replay-report.json --transcript quality/swarm-phase2-replay-transcript.txt --archive quality/swarm-phase2-replay-workspace",
    "eval:mirofish-flow": "node scripts/eval-mirofish-flow.mjs",
    "eval:personal-agent-flow": "node scripts/eval-personal-agent-flow.mjs",
    "eval:taxhacker-flow": "node scripts/eval-taxhacker-flow.mjs",
    "check:agb-start": "node scripts/check-agb-start-executable.mjs"
  },
  "dependencies": {},
  "description": "CLI for bootstrapping, checking, and analyzing Agent Buildprints for coding agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomEscobar/agent-buildprint.git"
  },
  "homepage": "https://agent-buildprint.com",
  "bugs": {
    "url": "https://github.com/DomEscobar/agent-buildprint/issues"
  },
  "keywords": [
    "agent-buildprint",
    "buildprint",
    "coding-agents",
    "ai-agents",
    "cli",
    "architecture",
    "blueprint"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/",
    "buildprints/",
    "docs/",
    "templates/",
    "scripts/",
    "README.md"
  ]
}
