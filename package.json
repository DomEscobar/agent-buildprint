{
  "name": "agent-buildprint",
  "version": "0.0.7",
  "type": "module",
  "bin": {
    "agb": "./bin/agb.js"
  },
  "dependencies": {},
  "scripts": {
    "check:syntax": "node --check bin/agb.js",
    "check:packet:mapper": "node bin/agb.js packet check buildprints/buildprint-mapper-os",
    "check:packet:swarm": "node bin/agb.js packet check buildprints/ai-swarm-simulator",
    "eval:mapper-overhaul": "node scripts/eval-mapper-overhaul.mjs",
    "eval:buildprint-variants": "node scripts/eval-buildprint-variants.mjs",
    "eval:buildprint-structures": "node scripts/eval-buildprint-structure-slices.mjs --help",
    "check:blueprint-yaml": "python3 -c \"import pathlib, yaml; [yaml.safe_load(p.read_text()) for p in pathlib.Path('buildprints').rglob('blueprint.yaml')]\""
  },
  "description": "CLI for bootstrapping Agent Buildprints for coding agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomEscobar/agent-buildprint.git"
  },
  "homepage": "https://agent-buildprint.com",
  "bugs": {
    "url": "https://github.com/DomEscobar/agent-buildprint/issues"
  },
  "keywords": [
    "agent-buildprint",
    "buildprint",
    "coding-agents",
    "ai-agents",
    "cli",
    "architecture",
    "blueprint"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/",
    "buildprints/",
    "docs/",
    "scripts/",
    "templates/",
    "README.md"
  ]
}
