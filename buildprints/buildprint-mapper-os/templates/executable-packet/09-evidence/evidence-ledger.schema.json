{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mapper OS Runtime Evidence Ledger Row",
  "type": "object",
  "required": [
    "capability_id",
    "claim",
    "proof_type",
    "artifact",
    "result",
    "provider_mode",
    "upgrades_claim"
  ],
  "properties": {
    "capability_id": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "proof_type": {
      "type": "string",
      "enum": [
        "unit_or_integration_test",
        "negative_test",
        "browser_trace",
        "runtime_trace",
        "persistence_roundtrip",
        "provider_integration_proof",
        "security_fixture_pass",
        "secret_redaction_scan",
        "clean_room_trace",
        "no_fake_scan",
        "evidence_ledger_entry",
        "blocker"
      ]
    },
    "artifact": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "provider_mode": {
      "type": "string",
      "enum": [
        "none",
        "deterministic",
        "sandbox_live",
        "production_live"
      ]
    },
    "upgrades_claim": {
      "type": "boolean"
    },
    "blocker": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
