{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "artifact_id",
    "type",
    "capability_id",
    "status",
    "source",
    "proves",
    "proof_type",
    "provider_mode",
    "upgrades_claim"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "proof",
        "blocker",
        "risk",
        "note"
      ]
    },
    "capability_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "missing",
        "passed",
        "proven",
        "blocked",
        "failed",
        "skipped"
      ]
    },
    "source": {
      "type": "string"
    },
    "proves": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof_type": {
      "type": "string"
    },
    "provider_mode": {
      "type": "string"
    },
    "upgrades_claim": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
