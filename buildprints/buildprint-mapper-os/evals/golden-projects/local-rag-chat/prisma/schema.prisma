datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id
  title     String
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id             String @id
  conversationId String
  role           String
  content        String
  groundingLevel String?
  citations      String?
}

model Document {
  id        String @id
  name      String
  status    String
  chunkCount Int   @default(0)
}

model MemoryItem {
  id       String @id
  type     String
  content  String
  useCount Int    @default(0)
}
