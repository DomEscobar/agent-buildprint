{
  "schemaVersion": "mapper-os/context-packet.v1",
  "executionMode": "continuous-full-suite",
  "activeCapability": "capabilities/01-active",
  "mustRead": [
    "CURRENT_STATE.md",
    "EXECUTION_PROTOCOL.md",
    "TEAM_STACK.md",
    "capabilities/01-active/CAPABILITY.md",
    "capabilities/01-active/IMPLEMENTATION.md",
    "capabilities/01-active/VERIFICATION.md",
    "capabilities/02-unrelated/CAPABILITY.md"
  ],
  "readIfNeeded": ["PRE_IMPLEMENTATION_QUESTIONS.md", "CONTRACTS.md"],
  "doNotReadYet": ["capabilities/* except capabilities/01-active/*"],
  "proofGate": {
    "capabilityVerification": "capabilities/01-active/VERIFICATION.md",
    "rootVerification": "VERIFICATION.md",
    "requiredBeforeAdvance": ["proof command or blocker"]
  },
  "advanceAfterProofTo": "capabilities/02-unrelated",
  "stopConditions": ["explicit blocker", "missing proof"]
}
