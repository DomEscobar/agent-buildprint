{
  "schemaVersion": "mapper-os/context-packet.v1",
  "executionMode": "continuous-full-suite",
  "activeCapability": "capabilities/01-ingestion-ontology",
  "mustRead": [
    "CURRENT_STATE.md",
    "EXECUTION_PROTOCOL.md",
    "TEAM_STACK.md",
    "capabilities/01-ingestion-ontology/CAPABILITY.md",
    "capabilities/01-ingestion-ontology/IMPLEMENTATION.md",
    "capabilities/01-ingestion-ontology/VERIFICATION.md"
  ],
  "readIfNeeded": [
    "PRE_IMPLEMENTATION_QUESTIONS.md",
    "UX_CONTRACT.md",
    "DESIGN_QUALITY_BAR.md",
    "PROVIDERS.md",
    "DATA_LIFECYCLE.md",
    "CONTRACTS.md"
  ],
  "doNotReadYet": [
    "CAPABILITY_INDEX.md until 01-ingestion-ontology proof closes and the next dependency-ready pack must be selected",
    "capabilities/* except capabilities/01-ingestion-ontology/*"
  ],
  "proofGate": {
    "capabilityVerification": "capabilities/01-ingestion-ontology/VERIFICATION.md",
    "rootVerification": "VERIFICATION.md",
    "requiredBeforeAdvance": [
      "upload-to-ontology proof command or explicit blocker",
      "durable project persistence artifact or explicit blocker",
      "unsupported/malformed upload negative tests",
      "browser screenshot proof for active ingestion UI state"
    ]
  },
  "advanceAfterProofTo": "capabilities/02-graph-builder",
  "stopConditions": [
    "explicit blocker",
    "missing proof",
    "provider/runtime uncertainty",
    "destructive safety issue",
    "secret exposure",
    "user interruption",
    "context/tooling limit"
  ]
}
