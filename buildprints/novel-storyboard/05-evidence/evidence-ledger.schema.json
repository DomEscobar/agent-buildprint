{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["timestamp", "phase_id", "proof_type", "command", "result", "artifacts"],
  "properties": {
    "timestamp": { "type": "string" },
    "phase_id": { "type": "string" },
    "proof_type": { "type": "string" },
    "command": { "type": "string" },
    "result": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
