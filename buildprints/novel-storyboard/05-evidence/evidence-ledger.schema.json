{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "artifact_id",
    "type",
    "phase_id",
    "status",
    "source",
    "proves",
    "proof_type",
    "provider_mode",
    "upgrades_claim",
    "claim_type"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "phase_id": {
      "type": "string"
    },
    "capability_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "missing",
        "passed",
        "proven",
        "blocked",
        "failed",
        "skipped"
      ]
    },
    "source": {
      "type": "string"
    },
    "proves": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof_type": {
      "enum": ["static", "unit_contract", "integration", "runtime_api", "browser_e2e", "screenshot_review", "persistence_restart", "provider_fake", "provider_live", "security_review", "no_fake_scan", "clean_room_reversal", "deployment_ops", "blocker"]
    },
    "provider_mode": {
      "enum": ["none", "fake", "deterministic", "sandbox", "live", "blocked", "missing_live_credentials", "not_applicable"]
    },
    "claim_type": {
      "enum": ["target", "core_pass", "claim_upgrade", "blocker"]
    },
    "upgrades_claim": {
      "type": "boolean"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocker": {
      "type": "string"
    },
    "blocks_continuation": {
      "type": "boolean"
    },
    "artifact_path": {
      "type": "string"
    },
    "trace_path": {
      "type": "string"
    },
    "screenshot_path": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
